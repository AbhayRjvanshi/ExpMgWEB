# ============================================================
# EXPENSE MANAGER - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# This file (.env.example) is a TEMPLATE showing what variables
# are required to run the application.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual credentials
# 3. .env is automatically gitignored (never committed)
# 4. .env.example stays in git as documentation
#
# SECURITY NOTE:
# - .env.example contains NO real secrets (all values are defaults)
# - .env contains YOUR actual credentials (keep it private)
# - .gitignore prevents .env from being committed to git
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=127.0.0.1          # MySQL server address (localhost for XAMPP)
DB_PORT=3306               # MySQL port (default: 3306)
DB_USER=root               # MySQL username (local dev: root)
DB_PASS=                   # MySQL password (local dev: empty for root)
DB_NAME=ExpMgWEB           # Database name

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
APP_ENV=development        # Environment: development, staging, production
APP_DEBUG=1                # Debug mode: 1 (on) or 0 (off)

# ============================================================
# NOTIFICATIONS CONFIGURATION
# ============================================================
# Backend: file (default) or redis
# Use 'file' for standard XAMPP/LAMP setups
# Use 'redis' for high-volume deployments (requires Redis server)
NOTIFICATIONS_BACKEND=file

# Redis connection (only used when NOTIFICATIONS_BACKEND=redis)
REDIS_HOST=127.0.0.1       # Redis server address
REDIS_PORT=6379            # Redis port (default: 6379)
# REDIS_PASSWORD=          # Redis password (if required)

